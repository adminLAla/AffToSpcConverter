<Window x:Class="InFalsusSongPackStudio.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于"
        Width="450"
        Height="250"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True">
    <Border Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="0"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource AppSurfaceAltBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid Margin="14,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="关于"
                               FontSize="15"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Width="30"
                            Height="26"
                            Padding="0"
                            FontSize="14"
                            Click="Close_Click">×</Button>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="18,14,18,8">
                <TextBlock Text="InFalsus SongPack Studio"
                           FontSize="22"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="VersionText"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                <TextBlock Margin="0,6,0,0"
                           Text="WPF/.NET"
                           Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                <TextBlock Margin="0,14,0,0"
                           Text="项目地址：https://github.com/adminLAla/InFalsus-SongPack-Studio"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Grid Grid.Row="2" Margin="0,0,14,12">
                <Button Width="96"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Click="Close_Click">确定</Button>
            </Grid>
        </Grid>
    </Border>
</Window>
