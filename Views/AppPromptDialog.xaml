<Window x:Class="InFalsusSongPackStudio.Views.AppPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="提示"
        Width="460"
        Height="230"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True">
    <Border Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="58"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource AppSurfaceAltBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid Margin="14,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="TitleText"
                               Text="提示"
                               FontSize="15"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Width="30"
                            Height="26"
                            Padding="0"
                            FontSize="14"
                            Click="Ok_Click">×</Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="18,12,18,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="28"
                        Height="28"
                        CornerRadius="14"
                        Background="{DynamicResource AppAccentBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        VerticalAlignment="Top"
                        Margin="0,2,10,0">
                    <TextBlock Text="i"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               FontSize="16"/>
                </Border>

                <TextBlock Grid.Column="1"
                           x:Name="MessageText"
                           TextWrapping="Wrap"
                           VerticalAlignment="Top"
                           Foreground="{DynamicResource AppForegroundBrush}"/>
            </Grid>

            <Grid Grid.Row="2" Margin="0,0,14,12">
                <Button Width="96"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Style="{DynamicResource AppButtonPrimary}"
                        Click="Ok_Click">确定</Button>
            </Grid>
        </Grid>
    </Border>
</Window>