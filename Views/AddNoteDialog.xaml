<Window x:Class="InFalsusSongPackStudio.Views.AddNoteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加音符" Height="420" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True">
    <Border Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource AppSurfaceAltBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid Margin="14,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="添加音符"
                               FontSize="15"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Width="30"
                            Height="26"
                            Padding="0"
                            FontSize="14"
                            Click="Close_Click">×</Button>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="12,10,12,6">
                <TextBlock Text="音符类型" Margin="0,0,0,4"/>
                <ComboBox x:Name="CbType" Width="250" HorizontalAlignment="Left"
                          SelectionChanged="CbType_SelectionChanged"/>

                <TextBlock Text="使用鼠标在预览中选择时间与位置" Margin="0,8,0,4" FontSize="11" Foreground="#888888"/>

                <StackPanel x:Name="PanelGround">
                    <TextBlock Text="Kind / Width（Tap 1-4, Hold 1-6）" Margin="0,12,0,4"/>
                    <TextBox x:Name="TbKind" Width="120" HorizontalAlignment="Left" Text="1"/>
                </StackPanel>

                <StackPanel x:Name="PanelSky" Visibility="Collapsed">
                    <TextBlock Text="分母（Den）" Margin="0,12,0,4"/>
                    <TextBox x:Name="TbDen" Width="120" HorizontalAlignment="Left" Text="24"/>
                    <TextBlock Text="宽度（WidthNum）" Margin="0,8,0,4"/>
                    <TextBox x:Name="TbWidthNum" Width="120" HorizontalAlignment="Left" Text="1"/>
                </StackPanel>

                <StackPanel x:Name="PanelFlick" Visibility="Collapsed">
                    <TextBlock Text="方向（4=右, 16=左）" Margin="0,8,0,4"/>
                    <ComboBox x:Name="CbDir" Width="120" HorizontalAlignment="Left">
                        <ComboBoxItem Content="4" IsSelected="True"/>
                        <ComboBoxItem Content="16"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel x:Name="PanelSkyArea" Visibility="Collapsed">
                    <TextBlock Text="拖动鼠标确定终点（默认直边，缓动=0）" Margin="0,8,0,4" FontSize="11" Foreground="#888888"/>
                </StackPanel>
            </StackPanel>

            <Grid Grid.Row="2" Margin="0,0,14,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                    <Button Width="90" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click">确定</Button>
                    <Button Width="90" IsCancel="True">取消</Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
