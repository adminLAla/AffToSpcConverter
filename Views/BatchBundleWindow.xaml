<Window x:Class="InFalsusSongPackStudio.Views.BatchBundleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="批量打包" Height="600" Width="900">
    <Window.Resources>
        <Style x:Key="BatchGridTextCellStyle" TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
        </Style>
        <Style x:Key="BatchGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="8,4,8,4"/>
        </Style>
    </Window.Resources>
    <Grid Background="{DynamicResource AppSurfaceBrush}" Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="620"/>
            <ColumnDefinition Width="360" MinWidth="320"/>
        </Grid.ColumnDefinitions>
        <!-- 左侧主流程区：资源定位 + 曲包列表。 -->
        <Grid Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Margin="0,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- 游戏资源定位区：显示并校验关键资源路径。 -->
            <GroupBox Header="资源文件" Grid.Row="0" Margin="0,0,0,8">
                <Grid Margin="10">
                    <TextBlock x:Name="ResourceLocateHintText"
                               Text="资源文件定位中..."
                               Foreground="{DynamicResource AppSubtleForegroundBrush}"
                               TextWrapping="Wrap"/>
                </Grid>
            </GroupBox>

            <!-- 批量处理区：导入 ZIP 并执行导出。 -->
            <GroupBox Header="批量处理曲包" Grid.Row="1" Margin="0,0,0,10">
                <Grid Margin="0,0,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="116"/>
                            <ColumnDefinition Width="Auto" MinWidth="116"/>
                            <ColumnDefinition Width="Auto" MinWidth="116"/>
                            <ColumnDefinition Width="*" MinWidth="0"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="导入文件夹" Click="BtnBatchImportFolder_Click" Margin="8,0,8,0" MinWidth="104" Height="30" FontSize="13"/>
                        <Button Grid.Column="1" Content="导入ZIP文件" Click="BtnBatchImportZipFiles_Click" Margin="8,0,8,0" MinWidth="104" Height="30" FontSize="13"/>
                        <Button Grid.Column="2" Content="批量导出" Click="BtnBatchExport_Click" Margin="8,0,8,0" MinWidth="104" Height="30" FontSize="13"/>
                    </Grid>
                    <Grid Grid.Row="1" Margin="0,0,0,0">
                        <DataGrid x:Name="SongPackDataGrid"
                              ItemsSource="{Binding SongPacks}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Margin="8,8,8,8"
                              MinHeight="380"
                              HeadersVisibility="Column"
                              CanUserResizeColumns="False"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ColumnHeaderStyle="{StaticResource BatchGridHeaderStyle}"
                              ColumnWidth="*">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="BaseName" Binding="{Binding BaseName}" Width="1.5*" MinWidth="110" ElementStyle="{StaticResource BatchGridTextCellStyle}" />
                                <DataGridTextColumn Header="SlotIndex" Binding="{Binding SlotIndex}" Width="1.2*" MinWidth="98" ElementStyle="{StaticResource BatchGridTextCellStyle}" />
                                <DataGridTextColumn Header="SongTitleEnglish" Binding="{Binding SongTitleEnglish}" Width="2*" MinWidth="130" ElementStyle="{StaticResource BatchGridTextCellStyle}" />
                                <DataGridTextColumn Header="SongArtistEnglish" Binding="{Binding SongArtistEnglish}" Width="2*" MinWidth="130" ElementStyle="{StaticResource BatchGridTextCellStyle}" />
                                <DataGridTextColumn Header="ChartCount" Binding="{Binding ChartCount}" Width="1.1*" MinWidth="96" ElementStyle="{StaticResource BatchGridTextCellStyle}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </GroupBox>

        </Grid>

        <!-- 右侧步骤与状态区：与“打包谱面”布局一致。 -->
        <Grid Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Margin="0,0,0,0" VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Header="操作步骤" Margin="0,0,0,8" VerticalContentAlignment="Top">
                <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Background="{DynamicResource AppSurfaceBrush}" Margin="10" VerticalAlignment="Top">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalAlignment="Top" MinHeight="520">
                        <TextBlock Text="{Binding OperationGuide}" TextWrapping="Wrap" Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                    </ScrollViewer>
                </Border>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Header="状态" Margin="0,8,0,0">
            <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Background="{DynamicResource AppSurfaceBrush}" Margin="10">
                <ListBox x:Name="StatusListBox" ItemsSource="{Binding Status}" MinHeight="120" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </GroupBox>
    </Grid>
</Window>
