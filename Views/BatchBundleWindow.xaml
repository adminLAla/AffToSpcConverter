<Window x:Class="InFalsusSongPackStudio.Views.BatchBundleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="批量打包" Height="600" Width="900">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="1.5*" />
        </Grid.ColumnDefinitions>
        <!-- 左侧主流程区：资源定位 + 曲包列表。 -->
        <StackPanel Grid.Column="0" Margin="0,0,0,0">
            <!-- 游戏资源定位区：显示并校验关键资源路径。 -->
            <GroupBox Header="资源文件" Margin="0,0,0,8">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="110"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="游戏目录：" VerticalAlignment="Center" Margin="0,0,8,6"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding GameDirectory}" IsReadOnly="True" Margin="0,0,8,6"/>
                    <Button Grid.Row="0" Grid.Column="2" Content="选择目录" Click="BtnBrowseGameDirectory_Click" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text=".bundle：" VerticalAlignment="Center" Margin="0,0,8,6"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding BundleFilePath}" IsReadOnly="True" Margin="0,0,8,6"/>
                    <Button Grid.Row="1" Grid.Column="2" Content="重新定位" Click="BtnBrowseGameDirectory_Click" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="sharedassets0.assets：" VerticalAlignment="Center" Margin="0,0,8,6"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SharedAssetsFilePath}" IsReadOnly="True" Margin="0,0,8,6"/>
                    <Button Grid.Row="2" Grid.Column="2" Content="重新定位" Click="BtnBrowseGameDirectory_Click" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="resources.assets：" VerticalAlignment="Center" Margin="0,0,8,6"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ResourcesAssetsFilePath}" IsReadOnly="True" Margin="0,0,8,6"/>
                    <Button Grid.Row="3" Grid.Column="2" Content="重新定位" Click="BtnBrowseGameDirectory_Click" Margin="0,0,0,6"/>
                </Grid>
            </GroupBox>

            <!-- 批量处理区：导入 ZIP 并执行导出。 -->
            <GroupBox Header="批量处理曲包" Margin="0,0,0,10" Width="600" Height="420">
                <Grid Margin="0,0,10,0" >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,8,0,0">
                        <Button Content="批量导入" Click="BtnBatchImport_Click" Margin="8,0,8,0"/>
                        <Button Content="批量导出" Click="BtnBatchExport_Click" Margin="8,0,8,0"/>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
                        <DataGrid x:Name="SongPackDataGrid"
                              ItemsSource="{Binding SongPacks}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Margin="8,8,8,8">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="BaseName" Binding="{Binding BaseName}" Width="*" />
                                <DataGridTextColumn Header="SlotIndex" Binding="{Binding SlotIndex}" Width="*" />
                                <DataGridTextColumn Header="SongTitleEnglish" Binding="{Binding SongTitleEnglish}" Width="*" />
                                <DataGridTextColumn Header="SongArtistEnglish" Binding="{Binding SongArtistEnglish}" Width="*" />
                                <DataGridTextColumn Header="ChartCount" Binding="{Binding ChartCount}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                    </ScrollViewer>
                </Grid>
            </GroupBox>

        </StackPanel>

        <!-- 右侧状态区：展示逐项处理结果与错误信息。 -->
        <GroupBox Header="状态" Grid.Column="1" Margin="0,0,0,0">
            <ListBox x:Name="StatusListBox" ItemsSource="{Binding Status}" />
        </GroupBox>
    </Grid>
</Window>
