<Window x:Class="InFalsusSongPackStudio.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Height="720"
        Width="1280"
        MinHeight="700"
        MinWidth="1100"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Duration x:Key="NavTransitionDuration">0:0:0.16</Duration>
        <LinearGradientBrush x:Key="NavSelectionIndicatorBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#A4D8FF" Offset="0"/>
            <GradientStop Color="#5EA7E6" Offset="0.56"/>
            <GradientStop Color="#2A628A" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="SidebarToggleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppSurfaceAltBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                             To="-1"
                                                             Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                             To="0"
                                                             Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppNavItemActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubtleHoverButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="-1"
                                                 Duration="0:0:0.12"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="0"
                                                 Duration="0:0:0.12"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="0"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Indicator"
                                    Width="2"
                                    HorizontalAlignment="Left"
                                    Margin="0,7,0,7"
                                    CornerRadius="1"
                                    Background="{StaticResource NavSelectionIndicatorBrush}"
                                    Opacity="0"/>
                            <Border x:Name="Container"
                                    Margin="6,0,0,0"
                                    CornerRadius="6"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Grid>
                                    <Border x:Name="SelectedOverlay" Background="{DynamicResource AppNavItemSelectedBrush}" Opacity="0" CornerRadius="6"/>
                                    <Border x:Name="HoverOverlay" Background="{DynamicResource AppSurfaceAltBrush}" Opacity="0" CornerRadius="6"/>
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HorizontalContentAlignment" Value="Center">
                                <Setter TargetName="Container" Property="Margin" Value="0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="-1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="Tag" Value="__selected__">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#F4F8FF"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SelectedOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="{StaticResource NavTransitionDuration}"/>
                                            <DoubleAnimation Storyboard.TargetName="Indicator"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="{StaticResource NavTransitionDuration}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SelectedOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="{StaticResource NavTransitionDuration}"/>
                                            <DoubleAnimation Storyboard.TargetName="Indicator"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="{StaticResource NavTransitionDuration}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="__selected__"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="0"/>
                            </MultiTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HomeActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppSurfaceAltBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                             To="-1.5"
                                                             Duration="0:0:0.14"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                             To="0"
                                                             Duration="0:0:0.14"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppNavItemActiveBrush}"/>
                                <Setter Property="Foreground" Value="#F4F8FF"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource AppSurfaceAltBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1"
            MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Border Width="18" Height="18" CornerRadius="4" Background="{DynamicResource AppAccentBrush}" Margin="0,0,8,0">
                        <TextBlock Text="IF"
                                   Foreground="White"
                                   FontSize="8"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="InFalsus SongPack Studio" VerticalAlignment="Center" FontFamily="Microsoft YaHei UI" FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button Style="{StaticResource SubtleHoverButtonStyle}" Width="38" Height="28" Padding="0" Click="MinimizeWindow_Click">─</Button>
                    <Button Style="{StaticResource SubtleHoverButtonStyle}" Width="38" Height="28" Padding="0" Margin="4,0,0,0" Click="ToggleMaximizeWindow_Click">□</Button>
                    <Button Width="38" Height="28" Padding="0" Margin="4,0,0,0" Click="CloseWindow_Click" Style="{DynamicResource AppButtonDanger}">×</Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

        <Border x:Name="SidebarRoot" Grid.Column="0"
                Margin="12"
                Padding="10"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="BrandTitleText" Text="InFalsus"
                                       FontSize="26"
                                       FontFamily="Microsoft YaHei UI Semibold"/>
                            <TextBlock x:Name="BrandSubTitleText" Text="SongPack Studio"
                                       Margin="0,2,0,0"
                                       Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                        </StackPanel>
                        <Button x:Name="BtnToggleSidebar" Grid.Column="1"
                                Margin="8,0,0,0" Padding="0"
                                VerticalAlignment="Top"
                                ToolTip="收缩/展开侧边栏"
                                Style="{StaticResource SidebarToggleButtonStyle}"
                                Click="ToggleSidebar_Click"></Button>
                    </Grid>

                    <Button x:Name="BtnNavHome" Style="{StaticResource NavButtonStyle}" Click="NavHome_Click" Tag="主页">主页</Button>
                    <Button x:Name="BtnNavBundle" Style="{StaticResource NavButtonStyle}" Click="NavBundle_Click" Tag="打包谱面">打包谱面</Button>
                    <Button x:Name="BtnNavBatch" Style="{StaticResource NavButtonStyle}" Click="NavBatch_Click" Tag="批量打包">批量打包</Button>
                    <Button x:Name="BtnNavRestore" Style="{StaticResource NavButtonStyle}" Click="NavRestore_Click" Tag="恢复写入文件">恢复写入文件</Button>
                    <Button x:Name="BtnNavConverterGroup" Style="{StaticResource NavButtonStyle}" Click="ToggleConverterSubmenu_Click" Tag="谱面转换">谱面转换</Button>
                    <StackPanel x:Name="ConverterSubmenuPanel" Margin="18,0,0,4">
                        <Button x:Name="BtnNavAffConverter" Style="{StaticResource NavButtonStyle}" Height="34" FontSize="12" Click="NavAffConverter_Click" Tag="AFF → SPC转换">AFF → SPC转换</Button>
                    </StackPanel>
                    <Button x:Name="BtnNavPreview" Style="{StaticResource NavButtonStyle}" Click="NavPreview_Click" Tag="谱面预览">谱面预览</Button>
                    <Button x:Name="BtnNavSettings" Style="{StaticResource NavButtonStyle}" Click="NavSettings_Click" Tag="设置" Margin="0,10,0,4">设置</Button>
                </StackPanel>

                <Button x:Name="BtnNavAbout" DockPanel.Dock="Bottom" Style="{StaticResource NavButtonStyle}" Click="ShowAbout_Click" Tag="关于">关于</Button>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="8,16,16,16">
            <Border
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid>
                    <Border x:Name="RestorePromptCard"
                            Visibility="Collapsed"
                            Margin="0"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="恢复写入文件" FontSize="23" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1"
                                       x:Name="RestorePromptText"
                                       FontSize="13"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource AppSubtleForegroundBrush}"/>

                            <Border Grid.Row="2"
                                    Margin="0,10,0,0"
                                    Padding="10"
                                    Background="{DynamicResource AppSurfaceBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="RestoreResultText"
                                               FontSize="13"
                                               FontFamily="Consolas"
                                               TextWrapping="Wrap"
                                               Visibility="Collapsed"/>
                                </ScrollViewer>
                            </Border>

                            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                <Button x:Name="BtnRestoreCancel" Style="{StaticResource SubtleHoverButtonStyle}" Width="96" Margin="0,0,8,0" FontSize="13" Click="RestoreCancel_Click">取消</Button>
                                <Button x:Name="BtnRestoreConfirm" Style="{StaticResource SubtleHoverButtonStyle}" Width="112" FontSize="13" Click="RestoreConfirm_Click">确认恢复</Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid x:Name="HomePanel">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource AppSurfaceAltBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="欢迎使用 InFalsus SongPack Studio"
                                           FontSize="22"
                                           FontWeight="SemiBold"/>
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                           Text="请选择一个功能开始，常用入口已放在下方。"/>
                                <TextBlock x:Name="HomeHintText"
                                           Margin="0,8,0,0"
                                           Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Background="{DynamicResource AppSurfaceAltBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16">
                            <UniformGrid Columns="2" Rows="2" Margin="0" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                                <Button Style="{StaticResource HomeActionButtonStyle}" Margin="0,0,8,8" Height="52" Padding="16,10" FontSize="16" FontWeight="SemiBold" BorderThickness="1.4" HorizontalContentAlignment="Left" Click="NavBundle_Click">打包谱面</Button>
                                <Button Style="{StaticResource HomeActionButtonStyle}" Margin="8,0,0,8" Height="52" Padding="16,10" FontSize="16" FontWeight="SemiBold" BorderThickness="1.4" HorizontalContentAlignment="Left" Click="NavBatch_Click">批量打包</Button>
                                <Button Style="{StaticResource HomeActionButtonStyle}" Margin="0,8,8,0" Height="52" Padding="16,10" FontSize="16" FontWeight="SemiBold" BorderThickness="1.4" HorizontalContentAlignment="Left" Click="NavAffConverter_Click">AFF → SPC转换</Button>
                                <Button Style="{StaticResource HomeActionButtonStyle}" Margin="8,8,0,0" Height="52" Padding="16,10" FontSize="16" FontWeight="SemiBold" BorderThickness="1.4" HorizontalContentAlignment="Left" Click="NavPreview_Click">谱面预览</Button>
                            </UniformGrid>
                        </Border>

                        <Border Grid.Row="2"
                                Background="{DynamicResource AppSurfaceAltBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,12,0,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                           Text="需要修改游戏目录或主题设置？"/>
                                <Button DockPanel.Dock="Right"
                                    Style="{StaticResource HomeActionButtonStyle}"
                                    Width="140"
                                    Height="42"
                                    Padding="12,6"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    BorderThickness="1.4"
                                        Click="NavSettings_Click">前往设置</Button>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <ContentControl x:Name="SectionContent"
                                    Visibility="Collapsed"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"/>
                </Grid>
            </Border>
        </Grid>
        </Grid>
    </Grid>
</Window>
