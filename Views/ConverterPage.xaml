<UserControl x:Class="InFalsusSongPackStudio.Views.ConverterPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:InFalsusSongPackStudio.Views"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">

    <UserControl.Resources>
        <Style x:Key="ToolbarIconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="ToolbarIconLightButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarIconButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
        </Style>
    </UserControl.Resources>

    <DockPanel Background="{DynamicResource AppSurfaceBrush}"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"
               LastChildFill="True">
        <!-- 内部状态开关：替代历史菜单项承载预览开关状态 -->
        <ToggleButton x:Name="PreviewModeToggle"
                      Visibility="Collapsed"
                      IsChecked="False"
                      IsEnabled="{Binding CanVisualPreview}"/>

        <!-- ===== 工具栏（文本编辑模式）- 仅在非预览状态显示 ===== -->
        <Border x:Name="ToolbarText" DockPanel.Dock="Top"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1" Padding="6,4"
            Background="{DynamicResource AppSurfaceAltBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 文件与转换按钮 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Margin="0,0,4,0" Padding="10,2" MinWidth="86" Click="BtnOpenAff_Click" ToolTip="打开 .aff">打开 AFF</Button>
                    <Button Margin="0,0,8,0" Padding="10,2" MinWidth="86" Click="BtnOpenSpc_Click" ToolTip="打开 .spc">打开 SPC</Button>

                    <Border Width="1" Margin="0,3,8,3" Background="{DynamicResource AppBorderBrush}"/>

                    <Button Style="{StaticResource ToolbarIconLightButtonStyle}" Margin="0,0,4,0" Click="BtnConvert_Click" ToolTip="执行转换">&#xE8AB;</Button>
                    <Button Style="{StaticResource ToolbarIconLightButtonStyle}" Margin="0,0,8,0" Click="BtnSaveSpc_Click" ToolTip="保存 .spc 文件">&#xE74E;</Button>

                    <Border Width="1" Margin="0,3,8,3" Background="{DynamicResource AppBorderBrush}"/>

                    <Button Style="{StaticResource ToolbarIconButtonStyle}" Margin="0,0,4,0" Click="BtnOpenVisualPreview_Click" ToolTip="可视化预览" IsEnabled="{Binding CanVisualPreview}">&#xE890;</Button>
                </StackPanel>

                <!-- 状态提示 -->
                <TextBlock Grid.Column="1" Text="{Binding Status}"
                           VerticalAlignment="Center" Margin="12,0" Foreground="{DynamicResource AppSubtleForegroundBrush}"/>
            </Grid>
        </Border>

        <!-- ===== 工具栏（预览模式）- 仅在预览状态显示 ===== -->
        <Border x:Name="ToolbarPreview" DockPanel.Dock="Top" Visibility="Collapsed"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1" Padding="6,4"
            Background="{DynamicResource AppSurfaceAltBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 背景音乐与播放控件 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Width="88" Margin="0,0,4,0" Click="BtnOpenBgm_Click">打开 BGM</Button>
                    <TextBlock Text="{Binding BgmFileName}" VerticalAlignment="Center"
                               Margin="0,0,8,0" Foreground="{DynamicResource AppSubtleForegroundBrush}" FontSize="12"/>
                    <Button Width="32" Margin="0,0,2,0" Click="BtnPlayPause_Click"
                            ToolTip="播放 / 暂停">
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="▶"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                            <Setter Property="Text" Value="⏸"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Width="32" Click="BtnRestart_Click" ToolTip="从头播放">↩</Button>
                    <Separator Margin="8,0,8,0"/>
                    <Button Padding="8,2" Margin="0,0,4,0" Click="BtnAddNote_Click" ToolTip="添加音符">＋</Button>
                    <Button x:Name="BtnDeleteNoteTop" Padding="8,2" Margin="0,0,4,0" Click="BtnDeleteNote_Click" ToolTip="删除音符">－</Button>
                    <Button x:Name="BtnEditNoteTop" Padding="8,2" Margin="0,0,4,0" Click="BtnEditNote_Click" ToolTip="编辑音符" FontFamily="Segoe UI Symbol" FontSize="14">✎</Button>
                    <Button x:Name="BtnUndoTop" Padding="8,2" Margin="0,0,4,0" Click="BtnUndoLastOperation_Click" ToolTip="撤回">↶</Button>
                    <Button x:Name="BtnRedoTop" Padding="8,2" Click="BtnRedoLastOperation_Click" ToolTip="恢复">↷</Button>
                </StackPanel>

                <!-- 状态提示 + 播放同步偏移 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="{Binding Status}"
                               VerticalAlignment="Center"
                               Foreground="#337733"/>
                    <TextBlock Text="播放同步偏移(ms):"
                               VerticalAlignment="Center"
                               Margin="18,0,4,0"
                               Foreground="{DynamicResource AppSubtleForegroundBrush}" FontSize="10"/>
                    <TextBox Width="64" Height="20"
                             VerticalContentAlignment="Center"
                             TextAlignment="Right"
                             FontFamily="Consolas" FontSize="11"
                             Text="{Binding PreviewSyncOffsetMs, Mode=TwoWay}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 主内容区 ===== -->
        <Grid x:Name="MainContentGrid">

            <!-- 层 0：文本面板（转换视图） -->
            <Grid x:Name="TextPanelsGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="120"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*" MinWidth="120"/>
                </Grid.ColumnDefinitions>

                <!-- 输入面板 -->
                <DockPanel Grid.Column="0">
                    <TextBlock DockPanel.Dock="Top" Text="输入 (.aff)"
                               FontSize="11" Foreground="{DynamicResource AppSubtleForegroundBrush}" Margin="4,2"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="46"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" Background="{DynamicResource AppSurfaceAltBrush}">
                            <TextBox x:Name="AffInputLineNumbersTextBox"
                                     FontFamily="Consolas" FontSize="12"
                                     VerticalScrollBarVisibility="Hidden"
                                     HorizontalScrollBarVisibility="Hidden"
                                     IsReadOnly="True" IsHitTestVisible="False" Focusable="False"
                                     BorderThickness="0" Background="Transparent"
                                     TextWrapping="NoWrap" Padding="4,4,6,4"
                                     TextAlignment="Right"/>
                        </Border>

                        <TextBox x:Name="AffInputTextBox"
                                 Grid.Column="1"
                                 Text="{Binding AffPreview}"
                                 TextChanged="AffInputTextBox_TextChanged"
                                 FontFamily="Consolas" FontSize="12"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 IsReadOnly="True" TextWrapping="NoWrap" Padding="4"/>
                    </Grid>
                </DockPanel>

                <GridSplitter Grid.Column="1" Width="4"
                              HorizontalAlignment="Stretch" Background="{DynamicResource AppBorderBrush}"/>

                <!-- 输出面板 -->
                <DockPanel Grid.Column="2">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,2">
                        <TextBlock Text="输出 (.spc)"
                                   FontSize="11" Foreground="{DynamicResource AppSubtleForegroundBrush}"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="BtnEditNoteText" Margin="8,0,0,0" Padding="10,2" MinWidth="70"
                            Click="BtnEditFromTextPanel_Click" ToolTip="编辑输出文本">编辑</Button>
                    <Button x:Name="BtnUndoText" Style="{StaticResource ToolbarIconButtonStyle}" Margin="4,0,0,0"
                            Click="BtnUndoTextEdit_Click" ToolTip="撤销上一步">&#xE7A7;</Button>
                    <Button x:Name="BtnRedoText" Style="{StaticResource ToolbarIconButtonStyle}" Margin="4,0,0,0"
                            Click="BtnRedoTextEdit_Click" ToolTip="恢复上一步">&#xE7A6;</Button>
                    <Button x:Name="BtnSaveSpcText" Style="{StaticResource ToolbarIconButtonStyle}" Margin="4,0,0,0"
                            Click="BtnValidateSpcText_Click" ToolTip="SPC 合法性检验">&#xE73E;</Button>
                    <Button Style="{StaticResource ToolbarIconButtonStyle}" Margin="8,0,0,0"
                            Click="BtnOpenVisualPreview_Click" ToolTip="打开可视化预览"
                        IsEnabled="{Binding CanVisualPreview}">&#xE890;</Button>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="46"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0" Background="{DynamicResource AppSurfaceAltBrush}">
                            <TextBox x:Name="SpcOutputLineNumbersTextBox"
                                     FontFamily="Consolas" FontSize="12"
                                     VerticalScrollBarVisibility="Hidden"
                                     HorizontalScrollBarVisibility="Hidden"
                                     IsReadOnly="True" IsHitTestVisible="False" Focusable="False"
                                     BorderThickness="0" Background="Transparent"
                                     TextWrapping="NoWrap" Padding="4,4,6,4"
                                     TextAlignment="Right"/>
                        </Border>

                        <TextBox x:Name="SpcOutputTextBox"
                                 Grid.Column="1"
                                 Text="{Binding SpcPreview, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TextChanged="SpcOutputTextBox_TextChanged"
                                 UndoLimit="{Binding TextEditUndoLimit}"
                                 FontFamily="Consolas" FontSize="12"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 AcceptsReturn="True"
                                 IsReadOnly="True" TextWrapping="NoWrap" Padding="4"/>
                    </Grid>
                </DockPanel>
            </Grid>

            <!-- 层 1：可视化预览覆盖层 -->
            <Grid x:Name="PreviewOverlay" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 预览工具栏 -->
                <Border Grid.Row="0" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1" Padding="6,4"
                    Background="{DynamicResource AppSurfaceAltBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="时间:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <Slider Width="220" Minimum="0"
                                    Maximum="{Binding PreviewMaxTimeMs}"
                                    Value="{Binding PreviewTimeMs, Mode=TwoWay}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding PreviewTimeMs, StringFormat={}{0}ms}"
                                       VerticalAlignment="Center" FontFamily="Consolas"
                                       MinWidth="64" Margin="4,0,12,0"/>

                            <TextBlock Text="流速:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <Slider Width="140" Minimum="500" Maximum="1500"
                                    Value="{Binding PreviewPixelsPerSecond, Mode=TwoWay}"
                                    VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" FontFamily="Consolas"
                                       MinWidth="64" Margin="4,0,12,0">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:0} px/s">
                                        <Binding Path="PreviewPixelsPerSecond"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <TextBlock Text="播放速度:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <Slider Width="120" Minimum="0.25" Maximum="1.5"
                                     TickFrequency="0.05"
                                     SmallChange="0.05"
                                     LargeChange="0.05"
                                     IsSnapToTickEnabled="True"
                                     Value="{Binding PreviewSpeed, Mode=TwoWay}"
                                     VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" FontFamily="Consolas"
                                       MinWidth="44" Margin="4,0,12,0"
                                       Text="{Binding PreviewSpeed, StringFormat={}{0:0.00}x}"/>

                            <TextBlock Text="Ctrl+滚轮=调流速  左键拖=滚动  右键拖=缩放  左键点击=选择"
                                       VerticalAlignment="Center" Foreground="{DynamicResource AppSubtleForegroundBrush}" FontSize="10"/>
                        </StackPanel>

                        <!-- 视图模式切换按钮 -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                            <Button Content="退出预览" Padding="8,3" Margin="0,0,8,0"
                                    Click="BtnExitPreview_Click" FontSize="11"/>
                            <Button x:Name="BtnMergedView" Content="合并视图" Padding="8,3"
                                    Margin="0,0,2,0" Click="OnMergedViewClick"
                                    FontSize="11"/>
                            <Button x:Name="BtnSplitView" Content="分离视图" Padding="8,3"
                                    Click="OnSplitViewClick"
                                    FontSize="11"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 预览区 + 属性面板 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="PropPanelColumn" Width="0"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 属性面板（左侧，选中音符时显示） -->
                    <Border x:Name="PropPanel" Grid.Column="0" Background="#FF1E1E2E"
                            BorderBrush="#555" BorderThickness="0,0,1,0"
                            Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,6">
                            <StackPanel x:Name="PropStack" Width="240">
                                <!-- 标题 -->
                                <TextBlock x:Name="PropHeader" Text="编辑音符"
                                           Foreground="#DDDDDD" FontSize="14" FontWeight="Bold"
                                           Margin="0,0,0,8"/>

                                <!-- 时间 (ms) -->
                                <TextBlock Text="时间 (ms)" Foreground="#AAAAAA" FontSize="11" Margin="0,4,0,2"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="−" Click="PropDecTime" FontSize="14" Padding="0"/>
                                    <TextBox x:Name="PropTime" Grid.Column="1" TextAlignment="Right"
                                             FontFamily="Consolas" FontSize="12" Margin="2,0"/>
                                    <Button Grid.Column="2" Content="+" Click="PropIncTime" FontSize="14" Padding="0"/>
                                </Grid>

                                <!-- 动态字段容器，由代码动态填充 -->
                                <StackPanel x:Name="PropFieldsPanel"/>

                                <!-- 应用 / 取消 -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                    <Button Content="✔ 应用" Padding="12,4" Margin="0,0,4,0"
                                            Click="PropApply_Click" FontSize="11"/>
                                    <Button Content="✕ 取消" Padding="12,4"
                                            Click="PropCancel_Click" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- 预览控件 -->
                    <views:SpcPreviewGLControl
                        x:Name="PreviewControl"
                        Grid.Column="1"
                        Events="{Binding PreviewEvents}"
                        JudgeTimeMs="{Binding PreviewTimeMs, Mode=TwoWay}"
                        PixelsPerSecond="{Binding PreviewPixelsPerSecond, Mode=TwoWay}"
                        Speed="1"
                        TargetFps="{Binding PreviewTargetFps}"
                        UseVsync="{Binding PreviewUseVsync}"
                        ShowFpsStats="{Binding ShowFpsStats}"/>
                </Grid>
            </Grid>

        </Grid>
    </DockPanel>
</UserControl>
